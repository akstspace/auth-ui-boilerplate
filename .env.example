# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection string used by Drizzle ORM
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# =============================================================================
# Better Auth
# =============================================================================

# Secret used to sign tokens and cookies (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Server-side Better Auth URL (used in auth.ts)
BETTER_AUTH_URL=http://localhost:3000

# Client-side Better Auth URL (exposed to the browser, used in auth-client.ts)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# Google OAuth
# =============================================================================
# Get these from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# Backend API (Optional)
# =============================================================================
# Only needed if you have an external backend service.
# If not set, backend testing features are disabled in the UI.

# Server-side backend URL (used by the API proxy route — NOT exposed to browser)
# BACKEND_API_URL=http://localhost:8080

# Client-side backend URL (used by the fetch/axios API clients in the browser)
# NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8080

# =============================================================================
# Email (SMTP via Nodemailer)
# =============================================================================
# Used for org invitation emails. Defaults to localhost:1025 (Mailpit) in dev.
#
# Local dev:  Use Mailpit (docker: axllent/mailpit) — SMTP on :1025, UI on :8025
# Production: Point at your provider's SMTP (SendGrid, Postmark, Gmail, AWS SES)

SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_SECURE=true
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
EMAIL_FROM="Auth UI <noreply@localhost>"
